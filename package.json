{
  "name": "azure-foundry-provider",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "description": "AI SDK provider for Azure AI Foundry and Azure OpenAI with intelligent endpoint routing, adaptive throttling, and operation-mismatch fallback recovery",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "prettier --write"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.58",
    "@ai-sdk/openai-compatible": "2.0.46",
    "@ai-sdk/provider": "3.0.10",
    "@ai-sdk/provider-utils": "4.0.26",
    "@azure/identity": "4.13.1",
    "ai": "6.0.174"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.13",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-license-header": "^0.9.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-multiline-arrays": "^4.1.7",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
