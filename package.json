{
  "name": "azure-foundry-provider",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Custom Azure Foundry provider for OpenCode/Kilo",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "lint:staged": "bunx eslint --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "format:staged": "bunx prettier --write"
  },
  "dependencies": {
    "@ai-sdk/openai": "2.0.91",
    "@ai-sdk/openai-compatible": "1.0.32",
    "@ai-sdk/provider": "2.0.1",
    "@ai-sdk/provider-utils": "3.0.21",
    "ai": "5.0.124"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.56.1"
  }
}
