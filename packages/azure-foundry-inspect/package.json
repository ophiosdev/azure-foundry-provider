{
  "$schema": "https://json.schemastore.org/package",
  "name": "azure-foundry-inspect",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Inspect Azure Foundry and Azure OpenAI deployments with the Cognitive Services management SDK",
  "bin": {
    "azure-foundry-inspect": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "eslint .",
    "inspect": "bun run ./src/cli.ts"
  },
  "dependencies": {
    "@azure/arm-cognitiveservices": "^8.1.0",
    "@azure/identity": "^4.13.0",
    "@inquirer/prompts": "^7.9.0",
    "ejs": "^5.0.1",
    "pretty-print-json": "^3.0.7",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/ejs": "^3.1.5",
    "@types/yargs": "^17.0.33",
    "typescript": "5.9.3"
  }
}
